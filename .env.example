# Secrets for scripts/ ONLY. Never imported by src/, never bundled into the app.
# Created automatically on first `npm run seed` if missing.

# Base58-encoded 32-byte private key for the seed funder / mock-USDC mint authority (devnet).
SEED_FUNDER_SECRET=

# The mock-USDC mint the seed created (also mirrored, as a public address, in src/scripts/lib/config.js).
SEED_USDC_MINT=

# Optional RPC overrides. Default to public devnet.
# RPC_URL=https://api.devnet.solana.com
# RPC_SUBSCRIPTIONS_URL=wss://api.devnet.solana.com
