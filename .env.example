# Secrets for scripts/ ONLY. Never imported by src/, never bundled into the app.
# Created automatically on first `npm run seed` if missing.

# Base58-encoded 32-byte private key for the seed funder / mock-USDC mint authority (devnet).
SEED_FUNDER_SECRET=

# The mock-USDC mint the seed created (also mirrored, as a public address, in src/scripts/lib/config.js).
SEED_USDC_MINT=

# RPC endpoint. Injected into the app at build time (build.js) and used by the seed script.
# Defaults to public devnet if unset. Use a keyed devnet provider (e.g. Helius) for reliability.
# On Vercel, set RPC_URL as a project env var instead of committing it.
# RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# RPC_SUBSCRIPTIONS_URL=wss://devnet.helius-rpc.com/?api-key=YOUR_KEY
