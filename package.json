{
	"name": "loonie",
	"version": "1.0.0",
	"description": "Pocket money, onchain — recurring allowances for Canadian families on Solana.",
	"author": "sero",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "npm-run-all --parallel dev:*",
		"dev:tailwind": "tailwindcss --input ./src/styles/tailwind.css --output ./dist/css/output.css --watch",
		"dev:js": "node build.js --watch",
		"dev:server": "npx serve dist -p 3000",
		"build": "npm-run-all build:clean build:parallel",
		"build:clean": "node clean.js",
		"build:parallel": "npm-run-all --parallel build:tailwind build:js build:copy",
		"build:tailwind": "tailwindcss --input ./src/styles/tailwind.css --output ./dist/css/output.css --minify",
		"build:js": "node build.js",
		"build:copy": "node copy.js",
		"seed": "node scripts/seed.js"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.1.18",
		"esbuild": "^0.27.3",
		"npm-run-all": "^4.1.5",
		"tailwindcss": "^4.1.18"
	},
	"dependencies": {
		"@solana-program/system": "^0.12.2",
		"@solana-program/token-2022": "^0.12.0",
		"@solana/kit": "^6.10.0",
		"@solana/subscriptions": "^0.3.0",
		"@wallet-standard/app": "^1.1.1",
		"gsap": "^3.15.0"
	}
}
